       <style>
           :root { --accent: #38bdf8; --bg: #030712; --card: rgba(31, 41, 55, 0.45); }
          
           /* v4 Final Font & Global Style */
           body {
               background: var(--bg); color: #f8fafc;
               font-family: 'Inter', sans-serif;
               margin: 0; padding: 0;
               overflow-x: hidden;
               -webkit-font-smoothing: antialiased;
           }
          
           /* Glassmorphism Header */
           header {
               position: sticky; top: 0; z-index: 1000;
               background: rgba(3, 7, 18, 0.85); backdrop-filter: blur(25px);
               border-bottom: 1px solid rgba(255,255,255,0.1); padding: 25px 5%;
               display: flex; justify-content: space-between; align-items: center;
           }
           .logo {
               font-family: 'Syncopate', sans-serif;
               font-size: 1.6rem; letter-spacing: -1px;
               color: var(--accent);
               text-transform: uppercase;
           }
          
           /* Team Filter Ribbon */
           .team-ribbon {
               display: flex; gap: 12px; padding: 15px 5%; overflow-x: auto;
               background: rgba(255,255,255,0.03); scrollbar-width: none;
               border-bottom: 1px solid rgba(255,255,255,0.05);
           }
           .t-badge {
               min-width: 52px; height: 52px; border-radius: 14px; background: var(--card);
               display: flex; align-items: center; justify-content: center; cursor: pointer;
               transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); border: 1px solid transparent;
           }
           .t-badge:hover { border-color: var(--accent); transform: scale(1.1) translateY(-2px); background: rgba(56,189,248,0.15); }
           .t-badge img { width: 36px; }


           /* Grid & Card Design */
           .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(310px, 1fr)); gap: 20px; padding: 35px 5%; }
           .card {
               background: var(--card); border-radius: 22px; padding: 24px;
               border: 1px solid rgba(255,255,255,0.06); cursor: pointer; transition: 0.3s;
               position: relative; overflow: hidden; will-change: transform;
           }
           .card:hover { border-color: var(--accent); transform: translateY(-6px); background: rgba(31, 41, 55, 0.7); }
           .card::before {
               content: ""; position: absolute; top: 0; left: 0; width: 5px; height: 100%;
               background: var(--t-color); opacity: 0.8;
           }
          
           .card-header { display: flex; align-items: center; gap: 18px; margin-bottom: 22px; }
           .p-thumb { width: 65px; height: 65px; border-radius: 50%; background: #000; border: 2.5px solid var(--t-color); }
           .name-area h3 { margin: 0; font-size: 1.15rem; font-weight: 800; }
           .name-area span { font-size: 0.75rem; color: #94a3b8; font-weight: 500; }


           /* Comparison Progress Bar */
           .comp-bar { height: 7px; background: #1e293b; border-radius: 4px; margin-top: 10px; overflow: hidden; }
           .comp-fill { height: 100%; background: var(--accent); border-radius: 4px; transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1); width: 0; }


           /* Modal V4 Visuals */
           .modal { display:none; position:fixed; z-index:2000; left:0; top:0; width:100%; height:100%; background:rgba(2, 6, 23, 0.94); backdrop-filter:blur(12px); }
           .modal-box {
               background: #0f172a; width: 92%; max-width: 880px; margin: 6vh auto;
               border-radius: 32px; border: 1px solid var(--accent); display: grid; grid-template-columns: 1fr 1.4fr; overflow: hidden;
               animation: modalFade 0.35s ease-out;
           }
           @keyframes modalFade { from { opacity: 0; transform: translateY(30px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
           .m-info { padding: 45px; border-right: 1px solid rgba(255,255,255,0.08); text-align: center; }
           .m-viz { padding: 45px; background: #020617; display: flex; flex-direction: column; justify-content: center; }
          
           /* Custom Search Bar */
           .search-box {
               background: #111827; border: 1px solid rgba(255,255,255,0.1);
               padding: 12px 22px; border-radius: 12px; color: white; width: 260px;
               outline: none; transition: 0.3s;
           }
           .search-box:focus { border-color: var(--accent); box-shadow: 0 0 15px rgba(56,189,248,0.2); }
       </style>
   </head>
